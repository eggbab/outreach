{
  "manifest_version": 3,
  "name": "Outreach - Instagram DM 자동화",
  "version": "1.0.0",
  "description": "웹 대시보드에서 관리하는 잠재고객에게 Instagram DM을 자동 발송합니다.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "http://localhost:8000/*",
    "https://*.outreach.app/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content-scripts/instagram-dm.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
